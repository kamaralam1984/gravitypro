NODE_ENV=development
PORT=3000

# PostgreSQL (Neon Cloud)
DATABASE_URL=postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/gravity?sslmode=require

# JWT
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_EXPIRES_IN=30d

# ─── OTP delivery ───────────────────────────────────────────────────────────
# PRIMARY: Email OTP via SMTP (free, no per-message cost).
# Leave ALL SMTP_* vars blank to use dev mode: OTP is logged to the console and
# returned as dev_otp in the API response (no email actually sent).
# SMTP_HOST=smtp.your-provider.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-smtp-username
# SMTP_PASS=your-smtp-password
# SMTP_FROM=Gravity <no-reply@gravitypro.kvlbusinesssolutions.com>

# OPTIONAL: Phone OTP via SMS (MSG91). Off by default to save cost — email is the
# primary channel. Leave MSG91_* blank to disable SMS (OTP logs to console /
# returns dev_otp). Only fill these in if you specifically need SMS delivery.
# MSG91_AUTH_KEY=your-msg91-auth-key
# MSG91_TEMPLATE_ID=your-msg91-template-id

# ─── Storage: Cloudflare R2 ─────────────────────────────────────────────────
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_NAME=gravity-assets
R2_PUBLIC_URL=https://assets.gravity.kvlbusinesssolutions.com

# ─── Traccar (self-hosted GPS) ──────────────────────────────────────────────
# Self-hosted Traccar server posts position updates to our webhook; this shared
# secret authenticates those internal calls.
TRACCAR_WEBHOOK_SECRET=traccar-internal-secret

# Push Notifications (Expo)
EXPO_ACCESS_TOKEN=your-expo-access-token

# BullMQ (optional - set when scaling horizontally, leave blank for node-cron mode)
# REDIS_URL=redis://localhost:6379
