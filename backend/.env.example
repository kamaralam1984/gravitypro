NODE_ENV=development
PORT=3000

# PostgreSQL (Neon Cloud)
DATABASE_URL=postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/gravity?sslmode=require

# JWT
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_EXPIRES_IN=30d

# Cloudflare R2
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_NAME=gravity-assets
R2_PUBLIC_URL=https://assets.gravity.trackalways.com

# Traccar Webhook (internal)
TRACCAR_WEBHOOK_SECRET=traccar-internal-secret

# Push Notifications (Expo)
EXPO_ACCESS_TOKEN=your-expo-access-token

# Phone OTP via SMS (MSG91) — leave blank to log OTP to console / return dev_otp
# MSG91_AUTH_KEY=your-msg91-auth-key
# MSG91_TEMPLATE_ID=your-msg91-template-id

# Email OTP via SMTP — leave blank to log OTP to console / return dev_otp
# SMTP_HOST=smtp.your-provider.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-smtp-username
# SMTP_PASS=your-smtp-password
# SMTP_FROM=Gravity <no-reply@gravitypro.kvlbusinesssolutions.com>

# BullMQ (optional - set when scaling horizontally, leave blank for node-cron mode)
# REDIS_URL=redis://localhost:6379
